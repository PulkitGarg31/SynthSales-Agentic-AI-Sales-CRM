# ─────────────────────────────────────────────────────────────
# SynthSales backend configuration.
# Copy this file to `.env` and fill in the values you have.
# The app boots even with placeholders — integrations degrade
# gracefully (they return a clear "not configured" result) until
# you add real credentials.
# ─────────────────────────────────────────────────────────────

# --- App ---
APP_NAME=SynthSales API
ENVIRONMENT=development
# Comma-separated list of allowed CORS origins (the Next.js frontend)
CORS_ORIGINS=http://localhost:3000

# --- Security ---
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-please-generate-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Database (matches docker-compose.yml; host port 5433 to avoid clashing
#     with any local Postgres on 5432) ---
DATABASE_URL=postgresql+psycopg://synthsales:synthsales_dev_pw@localhost:5433/synthsales

# --- Abuse-control rate limiter ---
# Leave REDIS_URL blank to use the in-memory limiter (correct at single-worker;
# resets on restart). Set it to a Redis URL to share buckets across workers /
# instances — required for a correct MULTI-worker deploy. On any Redis error the
# limiter degrades gracefully to the in-memory fallback.
REDIS_URL=
# Set true ONLY when a trusted reverse proxy fronts the app (every PaaS does):
# the auth/contact limiter then keys on the X-Forwarded-For client IP instead of
# the proxy's peer address. Keep false in local dev (XFF is attacker-controlled).
TRUST_PROXY=false

# --- AI provider ---
# Comma-separated priority chain with automatic failover on HTTP 429 (rate-limit)
# and a 60s cooldown. Recommended:
AI_PROVIDERS=gemini,groq,openrouter
# Single-provider override (ignored if AI_PROVIDERS is set).
# "auto" → gemini → groq → openrouter, depending on which keys are present.
AI_PROVIDER=auto
# Google Gemini — https://aistudio.google.com/apikey  (generous free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Groq — https://console.groq.com/keys  (ongoing free tier, fast Llama)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# OpenRouter — https://openrouter.ai/settings/keys  (`:free` models = truly free, rate-limited)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Web search ---
# DuckDuckGo (`ddgs`) needs no key but gets rate-limited from datacenter IPs, so
# it fails on most deploys. For production set Serper.io (real Google results):
# https://serper.dev — 2,500 free credits per account. SERPER_API_KEYS is a
# comma-separated pool drained ONE key at a time (a key is used until it runs out
# of credits, then the next takes over). SEARCH_ORDER picks which backend is tried
# first; the default `ddgs,serper` uses the free scraper locally and falls through
# to Serper when ddgs is blocked (a circuit breaker stops retrying a dead ddgs).
SERPER_API_KEYS=
SEARCH_ORDER=ddgs,serper

# --- Email verification ---
# The free syntax/MX layer always runs (no key). For authoritative mailbox
# confirmation, set a paid provider below. Verifalia is used preferentially when
# configured (more credits); ZeroBounce is the fallback.
# Verifalia: https://verifalia.com/client-area
VERIFALIA_USERNAME=
VERIFALIA_PASSWORD=
# ZeroBounce: https://www.zerobounce.net  (100 free verifications/mo)
ZEROBOUNCE_API_KEY=
# Hunter.io email finder — ONE lookup per company finds the top contact's real
# email + the company mail domain. Free tier is small. https://hunter.io/api-keys
HUNTER_API_KEY=

# --- Email sending/reading ---
# Either configure Gmail OAuth (preferred) OR plain SMTP below.
# Gmail: download OAuth client JSON and a stored token, then point to them:
GMAIL_CREDENTIALS_FILE=
GMAIL_TOKEN_FILE=
# OR simple SMTP (e.g. Gmail App Password):
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=SynthSales <no-reply@synthsales.example>

# --- Google OAuth (sign-in / sign-up) ---
# Optional. Leave CLIENT_ID/SECRET blank to disable: the "Continue with Google"
# button hides and the OAuth routes return 404. To enable, create an OAuth 2.0
# "Web application" client at https://console.cloud.google.com/apis/credentials
# and add GOOGLE_REDIRECT_URI below to its "Authorized redirect URIs" exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback
# Per-user Google Calendar connection (auto Google Meet links on booking).
# Add this URI to the OAuth client's Authorized redirect URIs, enable the
# Google Calendar API in the project, and note that calendar.events is a
# "sensitive" scope (needs app verification before external production use).
GOOGLE_CALENDAR_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/calendar/callback
# Per-user Gmail read connection (Step 05 reply detection). Add this URI to the
# OAuth client's Authorized redirect URIs and enable the Gmail API in the project.
# gmail.readonly is a "restricted" scope (needs app verification before external
# production use; fine for testing with your own account).
GOOGLE_MAILBOX_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/mailbox/callback
# Where the backend redirects the SPA after a successful Google callback.
FRONTEND_URL=http://localhost:3000

# --- Outreach / follow-up automation ---
# How often the tracking agent polls inboxes (PRD says 15 minutes)
FOLLOWUP_INTERVAL_MINUTES=15
# How long a thread sits unanswered (our last message) before an auto follow-up.
# Decoupled from the poll cadence above. Max nudges before a thread auto-stalls.
FOLLOWUP_DELAY_DAYS=7
MAX_FOLLOW_UPS=3
# Default generated-meeting length (minutes).
MEETING_DEFAULT_DURATION_MINUTES=30
# Set to false to disable the background scheduler entirely
ENABLE_SCHEDULER=true
# How often the inbound poller reads each connected mailbox for new replies.
INBOUND_POLL_MINUTES=5
# Minimum AI confidence before a "not interested" reply opts the contact out.
REPLY_OPTOUT_MIN_CONFIDENCE=70
# IMAP fallback (single global mailbox) for inbound reading when no per-user Gmail
# token is connected. Leave blank to disable.
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

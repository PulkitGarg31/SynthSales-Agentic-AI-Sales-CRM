# Copy to `.env` on the VM and fill in. NEVER commit the real .env (see .gitignore).
# Values marked __...__ are yours to supply; copy the integration keys from your
# local backend/.env.

# --- Core (VM-specific) ---
ENVIRONMENT=production
SECRET_KEY=__generate__            # python3 -c "import secrets; print(secrets.token_urlsafe(48))"
TRUST_PROXY=true
POSTGRES_PASSWORD=__choose_a_strong_password__
DATABASE_URL=postgresql+psycopg://synthsales:__same_password_as_above__@db:5432/synthsales
REDIS_URL=redis://redis:6379/0

# --- URLs (set AFTER the Vercel deploy) ---
CORS_ORIGINS=https://__your-project__.vercel.app
FRONTEND_URL=https://__your-project__.vercel.app

# --- Email (Brevo, HTTPS — already integrated) ---
BREVO_API_KEY=__xkeysib-...__
SMTP_FROM=SynthSales <__your-brevo-verified-sender@gmail.com__>

# --- Search / AI / verification / hunter (copy values from local backend/.env) ---
SERPER_API_KEYS=__copy__
SEARCH_ORDER=serper,ddgs
AI_PROVIDERS=gemini,groq,openrouter
GEMINI_API_KEY=__copy__
GROQ_API_KEY=__copy__
OPENROUTER_API_KEY=__copy__
VERIFALIA_USERNAME=__copy__
VERIFALIA_PASSWORD=__copy__
ZEROBOUNCE_API_KEY=__copy__
HUNTER_API_KEY=__copy__

# --- Admin + contact ---
ADMIN_EMAILS=gargp6430@gmail.com,brodomyjob@gmail.com

# --- Google OAuth (optional; redirects point at the DuckDNS API host) ---
GOOGLE_CLIENT_ID=__copy__
GOOGLE_CLIENT_SECRET=__copy__
GOOGLE_REDIRECT_URI=https://synthsales.duckdns.org/api/auth/google/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://synthsales.duckdns.org/api/auth/google/calendar/callback
GOOGLE_MAILBOX_REDIRECT_URI=https://synthsales.duckdns.org/api/auth/google/mailbox/callback
